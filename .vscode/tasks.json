{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build with SFML",
            "command": "g++.exe",
            "args": [
                "-g",
                "*.cpp",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe",
                
                // === هتحط مساراتك أنت الفعلية هنا ===
                
               // على جهازك SFML الخاص بـ include التعديل هنا: حط مسار فولدر الـ
            // مسار include الجديد بتاع MSYS2
            "-I", "C:\\msys64\\ucrt64\\include",
            
            // مسار lib الجديد بتاع MSYS2
            "-L", "C:\\msys64\\ucrt64\\lib",

            
            "-lsfml-graphics",
            "-lsfml-window",
            "-lsfml-system"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "compiler: g++.exe"
        }
    ]
}